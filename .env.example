# ============================================================================
# Gruve AI Vibe Coding Demo — environment configuration
# Copy this file to .env in the repo root, then fill in what you have.
# Every value below has a safe fallback, so the app runs even with an
# empty .env (it drops into MOCK MODE for the LLM calls).
# ============================================================================

# --- LLM provider (Anthropic Claude) ---------------------------------------
# Get a key at https://console.anthropic.com/  Leave blank to run fully
# offline in mock mode (canned but realistic responses, clearly labeled).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Backend (Node/Express, REST API + RAG + Agents) ------------------------
PORT=4000

# Python microservice that generates text embeddings for the RAG pipeline.
PYTHON_EMBEDDING_SERVICE_URL=http://localhost:8001

# Path (relative to backend/) to the compiled MCP server entrypoint that the
# agent spawns over stdio. Only used when running the agent in "MCP tool"
# mode (see mcp-server/README notes in codebase.md).
MCP_SERVER_ENTRY=../mcp-server/dist/index.js

# --- Python embeddings microservice (FastAPI) --------------------------------
EMBEDDING_SERVICE_PORT=8001

# --- Frontend (Next.js) ------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
