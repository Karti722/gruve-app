# ============================================================================
# AI Nexus: environment configuration
# Copy this file to .env in the repo root, then fill in what you have.
# Most values below have a safe fallback: leave ANTHROPIC_API_KEY blank and
# chat/RAG/agent/summarize (abstractive) drop into MOCK MODE instead of
# failing. VOYAGE_API_KEY is the one exception, with no fallback: RAG,
# semantic caching and extractive summarization all depend on real
# embeddings and will fail loudly without a real key rather than silently
# degrade (see python-service/app/embeddings.py for why).
#
# Each variable below shows its LOCAL DEV default (the actual value used when
# you copy this file as-is) plus a DEPLOYED example showing what the same
# variable looks like once you follow deployment.md. None of the deployed
# values are typed into a real .env file in production, Cloud Run injects
# them as real environment variables/secrets directly onto the container;
# they're shown here purely so you can see every value in one place.
# ============================================================================

# --- LLM provider (Anthropic Claude) ---------------------------------------
# Get a key at https://console.anthropic.com/  Leave blank to run fully
# offline in mock mode (canned but realistic responses, clearly labeled).
# Deployed: stored as the Secret Manager secret `anthropic-api-key`, e.g.
# ANTHROPIC_API_KEY=sk-ant-api03-REAL_KEY_FROM_CONSOLE (see deployment.md Step 3)
ANTHROPIC_API_KEY=
# Same value locally and deployed, this repo's default model.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Backend (Node/Express, REST API + RAG + Agents) ------------------------
# Same value locally and deployed, matches backend/Dockerfile's EXPOSE port.
PORT=4000

# Origin(s) the backend's CORS policy allows to call it from a browser.
# Comma-separate multiple origins (e.g. a staging URL and a prod URL). Must
# match wherever the frontend is actually served from; in deployment this is
# the frontend's public HTTPS URL, NOT localhost (see deployment.md).
# Deployed example: https://frontend-abcd1234-uc.a.run.app
# (or https://ai-nexus.app if you've mapped a custom domain)
FRONTEND_URL=http://localhost:3000

# Python microservice that generates text embeddings for the RAG pipeline.
# Deployed example: the internal-only URL Cloud Run prints when you deploy
# python-service, e.g. https://python-service-abcd1234-uc.a.run.app
# (captured automatically into a variable in deployment.md, never typed by hand)
PYTHON_EMBEDDING_SERVICE_URL=http://localhost:8001

# Path (relative to backend/) to the compiled MCP server entrypoint that the
# agent spawns over stdio. Only used when running the agent in "MCP tool"
# mode (see mcp-server/README notes in codebase.md).
# Deployed: not set at all, backend/Dockerfile already bakes in the correct
# absolute path (/app/mcp-server/dist/index.js) for the container image.
MCP_SERVER_ENTRY=../mcp-server/dist/index.js

# Real current-weather data for the agent's get_weather tool (mcp-server/),
# via WeatherAPI.com: get a free key at https://www.weatherapi.com/ (100,000
# calls/month, no credit card). Set here on the backend, not on mcp-server
# directly: the backend spawns mcp-server as a child process and forwards
# its own environment to it (see backend/src/agent/mcpClient.ts). No
# fallback if this is missing, but unlike VOYAGE_API_KEY, the blast radius
# is just this one tool call returning an error, not the whole app failing:
# get_current_time and list_ai_concepts share this same server process and
# don't need this key at all.
MCP_WEATHER_API_KEY=

# pgvector-enabled Postgres instance backing the RAG vector store. Start it
# with `npm run db:up` (just the postgres container) or via full
# `docker compose up`. Port 5433, not 5432, so it won't clash with a default
# local Postgres install.
# Deployed: stored as the Secret Manager secret `postgres-url`, a real Neon
# connection string, e.g.
# postgresql://neondb_owner:REAL_PASSWORD@ep-cool-forest-123456.us-east-2.aws.neon.tech/nexus_vectors?sslmode=require
# (see deployment.md Step 1 and Step 3)
POSTGRES_URL=postgresql://nexus:nexus@localhost:5433/nexus_vectors

# --- Python embeddings microservice (FastAPI) --------------------------------
# Same value locally and deployed, matches python-service/Dockerfile's EXPOSE port.
EMBEDDING_SERVICE_PORT=8001

# Real embeddings via Voyage AI (voyage-4-lite), Anthropic's own recommended
# embeddings partner: get a free key at https://dashboard.voyageai.com/
# (200 million free tokens on this model family, no credit card). Required:
# there is no offline/mock fallback for embeddings, unlike the LLM calls
# above, since a fabricated embedding would silently corrupt the vector
# store rather than just producing a canned reply.
# Deployed: stored as the Secret Manager secret `voyage-api-key` (see deployment.md).
VOYAGE_API_KEY=

# --- Frontend (Next.js) ------------------------------------------------------
# Build-time only: baked into the frontend's static JS when it's built, not
# read at runtime. Deployed example: the backend's public Cloud Run URL, e.g.
# https://backend-abcd1234-uc.a.run.app (or https://api.ai-nexus.app with a
# custom domain mapped). See deployment.md Step 5.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
